{
  "paths": {
    "outputRoot": "./output",
    "dashRoot": "./output/dash"
  },
  "capture": {
    "inputFormat": "avfoundation",
    "inputSource": "0:none",
    "frameRate": 30,
    "pixelFormat": "uyvy422",
    "videoSize": "1280x720",
    "audioDevice": null
  },
  "streaming": {
    "segmentDurationSeconds": 4,
    "dvrWindowSeconds": 120
  },
  "server": {
    "host": "127.0.0.1",
    "port": 8090
  },
  "motion": {
    "enabled": false,
    "threshold": 0.2
  },
  "thumbnails": {
    "intervalSeconds": 10
  }
}
