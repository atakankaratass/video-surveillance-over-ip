{
  "name": "cs418-project-2-video-surveillance",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "list:devices": "tsx scripts/list-avfoundation-devices.ts",
    "demo:check": "tsx scripts/demo-check.ts",
    "latency:run": "tsx scripts/run-latency-matrix.ts",
    "startup:prepare": "npm run build && tsx scripts/dev.ts",
    "startup:nginx": "npm run build && tsx scripts/dev.ts --start-nginx",
    "startup:ffmpeg": "npm run build && tsx scripts/dev.ts --start-ffmpeg",
    "startup:all": "npm run build && tsx scripts/dev.ts --start-all",
    "startup:audio": "npm run build && tsx scripts/dev.ts --start-all --audio",
    "startup:stop": "tsx scripts/stop-live-demo.ts",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "npm run build && playwright test",
    "e2e:headed": "npm run build && playwright test --headed",
    "validate:env": "tsx scripts/validate-environment.ts",
    "validate:push": "npm run lint && npm run typecheck && npm run test && npm run build && npm run e2e",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.15.18",
    "@playwright/test": "^1.52.0",
    "dashjs": "^5.0.3",
    "eslint": "^9.26.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vite": "^6.3.5",
    "vitest": "^3.1.3"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,html,css}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
